---
import Layout from '../layouts/Layout.astro';
import TerminalHero from '../components/TerminalHero.astro';
import TipRoulette from '../components/TipRoulette.tsx';
import tipsData from '../data/tips.json';
---

<Layout title="Home">
	<header class="page-header animate-in">
		<h1 class="page-title"><span class="gradient-text">Nirmal's</span> Shell</h1>
		<p class="page-subtitle">
			A living guide to aliases, functions, tips, and workflows — extracted directly from 
			<a href="https://github.com/Thundernirmal/zsh" target="_blank" rel="noopener noreferrer" style="text-decoration: underline; text-underline-offset: 4px; color: var(--text-main);">
				github.com/Thundernirmal/zsh
			</a>
		</p>
	</header>

	<div>
		<TerminalHero />
	</div>

	<div class="panel-grid panel-grid-2 animate-in animate-in-4">
		<!-- Left Pane: Command Reference -->
		<section class="panel" style="display: flex; flex-direction: column; justify-content: center; text-align: center; padding: 2.5rem 1.5rem;">
			<h2 class="panel-title panel-title-lg">Command Library</h2>
			<p class="panel-copy" style="margin-bottom: 2rem;">
				Search and explore the complete library of custom commands, aliases, and workflows configuring this environment.
			</p>
			<div class="panel-actions">
				<a href="/commands" class="btn btn-lg">Browse Commands</a>
			</div>
		</section>

		<!-- Right Pane: Interactive Tips -->
		<section class="panel" style="display: flex; flex-direction: column; padding: 1.5rem;">
			<div class="panel-header" style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1.5rem;">
				<h2 class="panel-title panel-title-md" style="margin: 0;">Shell Tips</h2>
				<a href="/tips" class="text-button" style="text-decoration: none; font-size: 0.8rem;">View All {tipsData.length} →</a>
			</div>
			<div style="flex: 1; display: flex; flex-direction: column;">
				<TipRoulette client:load />
			</div>
		</section>
	</div>
</Layout>
