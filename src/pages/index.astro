---
import Layout from '../layouts/Layout.astro';
import TerminalHero from '../components/TerminalHero.astro';
import TipRoulette from '../components/TipRoulette.tsx';
import commandsData from '../data/commands.json';
import tipsData from '../data/tips.json';

type Command = {
	name: string;
	category?: string;
	examples?: string[];
	features?: string[];
	notes?: string[];
};

type Tip = {
	text: string;
	source?: string;
	availability?: string;
};

const commands: Command[] = commandsData;
const tips: Tip[] = tipsData;
const categoryCount = new Set(commands.map((command) => command.category).filter(Boolean)).size;
const featuredTip = tips.find((tip) => tip.source === 'upkg')?.text ?? tips[0]?.text ?? 'Run tips again for another hint';
const upkgExamples = commands.find((command) => command.name === 'upkg')?.examples ?? [];
const upkgExample = upkgExamples.find((example) => example.includes('search')) ?? upkgExamples[0] ?? 'upkg search ripgrep';
const npkgExample = commands.find((command) => command.name === 'npkg')?.examples?.[1] ?? 'npkg find nvim';
---

<Layout title="Home">
	<header class="page-header animate-in">
		<h1 class="page-title"><span class="gradient-text">Nirmal's</span> Shell</h1>
		<p class="page-subtitle">
			A living guide to aliases, functions, tips, and workflows — extracted directly from 
			<a href="https://github.com/Thundernirmal/zsh" target="_blank" rel="noopener noreferrer" class="page-subtitle-link">
				github.com/Thundernirmal/zsh
			</a>
		</p>
	</header>

	<div>
		<TerminalHero featuredTip={featuredTip} upkgExample={upkgExample} npkgExample={npkgExample} />
	</div>

	<div class="panel-grid panel-grid-2 animate-in animate-in-4">
		<!-- Left Pane: Command Reference -->
		<section class="panel panel-center panel-roomy">
			<h2 class="panel-title panel-title-lg">Command Library</h2>
			<p class="panel-copy panel-copy-spaced">
				Search {commands.length} commands across {categoryCount} categories, including extracted usage, examples, requirements, and feature notes from the live shell sources.
			</p>
			<p class="panel-copy panel-copy-spaced">
				From <code>upkg search ripgrep</code> to <code>npkg add bat</code>, quick aliases like <code>ll</code> and <code>lt</code>, and more — all documented with usage, options, and availability notes.
			</p>
			<p class="panel-copy panel-copy-spaced">
				Filter by type — aliases, functions, or key bindings — and search instantly with results synced to the URL for easy sharing.
			</p>
			<div class="panel-actions">
				<a href="/commands" class="btn btn-lg">Browse Commands</a>
			</div>
		</section>

		<!-- Right Pane: Interactive Tips -->
		<section class="panel panel-stack">
			<div class="panel-header panel-header-split">
				<h2 class="panel-title panel-title-md">Shell Tips</h2>
				<a href="/tips" class="text-button text-button-sm">View All {tips.length} →</a>
			</div>
			<p class="panel-copy panel-copy-spaced">
				Review always-on shortcuts and conditional features side by side, with availability notes carried through from the zsh config.
			</p>
			<div class="panel-fill">
				<TipRoulette client:load />
			</div>
		</section>
	</div>
</Layout>
