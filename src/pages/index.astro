---
import Layout from '../layouts/Layout.astro';
import TerminalHero from '../components/TerminalHero.astro';
import TipRoulette from '../components/TipRoulette.tsx';
import commandsData from '../data/commands.json';
import tipsData from '../data/tips.json';

const aliasCount = commandsData.filter(c => c.type === 'alias').length;
const functionCount = commandsData.filter(c => c.type === 'function').length;
const globalCount = commandsData.filter(c => c.type === 'global_alias').length;
---

<Layout title="Home">
	<!-- Hero Section -->
	<header class="animate-in" style="margin-bottom: 3rem; padding-top: 1rem;">
		<h1><span class="gradient-text">Nirmal's</span> Shell</h1>
		<p class="page-subtitle">
			A living guide to aliases, functions, tips, and workflows — extracted directly from a real shell environment.
		</p>
	</header>

	<!-- Terminal Demo -->
	<div style="margin-bottom: 3rem;">
		<TerminalHero />
	</div>

	<!-- Primary CTA Grid -->
	<div class="geist-grid geist-grid-2 animate-in animate-in-4" style="margin-bottom: 3rem;">
		<!-- Hero Panel as Grid Item -->
		<div class="geist-grid-item" style="display: flex; flex-direction: column; justify-content: center;">
			<h2 style="font-size: 1.75rem; margin-bottom: 0.75rem;">Explore Workflows</h2>
			<p style="margin-bottom: 1.5rem; font-size: 1rem; flex: 1;">
				Search and explore the complete library of custom commands, aliases, and shortcuts that power this environment.
			</p>
			<div>
				<a href="/commands" class="btn">Search Directory →</a>
			</div>
		</div>
		
		<!-- Stats Grid built into the main grid block for Vercel flair -->
		<div class="geist-grid-item" style="display: flex; flex-direction: column; justify-content: space-between;">
			<div style="display: flex; flex-direction: column; gap: 1rem;">
				<div>
					<div style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-faint); margin-bottom: 0.25rem;">ALIASES</div>
					<div style="font-size: 2rem; font-family: var(--font-display); font-weight: 600; line-height: 1; color: var(--ctp-blue);">{aliasCount}</div>
				</div>
				<div>
					<div style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-faint); margin-bottom: 0.25rem;">FUNCTIONS</div>
					<div style="font-size: 2rem; font-family: var(--font-display); font-weight: 600; line-height: 1; color: var(--ctp-green);">{functionCount}</div>
				</div>
				<div>
					<div style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-faint); margin-bottom: 0.25rem;">GLOBALS</div>
					<div style="font-size: 2rem; font-family: var(--font-display); font-weight: 600; line-height: 1; color: var(--ctp-peach);">{globalCount}</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Bottom Grid -->
	<div class="geist-grid geist-grid-2" style="margin-bottom: 2rem;">
		<a href="/tips" class="geist-grid-item geist-grid-item-hover" style="display: flex; flex-direction: column; justify-content: center; text-decoration: none;">
			<h3 style="font-size: 1.1rem; margin-bottom: 0.25rem; color: var(--text-main);">Shell Tips →</h3>
			<p style="font-size: 0.9rem; margin: 0; color: var(--text-muted);">{tipsData.length} curated tips on navigation, git, fzf, globbing, and more.</p>
		</a>

		<div class="geist-grid-item" style="display: flex; flex-direction: column;">
			<h3 style="font-size: 1.1rem; margin-bottom: 0.5rem; color: var(--text-main);">Tip Roulette</h3>
			<div style="flex: 1; display: flex; flex-direction: column; min-height: 0;">
				<TipRoulette client:load />
			</div>
		</div>
	</div>
</Layout>