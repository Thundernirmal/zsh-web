---
import Layout from '../layouts/Layout.astro';
import TipsExplorer from '../components/TipsExplorer.tsx';
import tipsData from '../data/tips.json';

type Tip = { text: string; category: string };
const tips: Tip[] = tipsData;
---

<Layout title="Shell Tips">
	<header class="page-header animate-in">
		<h1 class="page-title">Shell Tips</h1>
		<p class="page-subtitle">
			{tips.length} curated tips — shortcuts, workflows, and hidden features from <span class="accent-text page-subtitle-accent">Nirmal's Shell</span>.
		</p>
	</header>

	<TipsExplorer client:load tips={tips} />
</Layout>
